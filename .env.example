# Server
PORT=9527

# Database: sqlite for local/dev, mysql for production.
DB_TYPE=sqlite
DB_PATH=app.db

# MySQL example:
# DB_TYPE=mysql
# DB_DSN=kiroclaim:change_me@tcp(127.0.0.1:3306)/kiroclaim?charset=utf8mb4&parseTime=True&loc=Local

# Optional Prometheus metrics basic auth.
# METRICS_USER=
# METRICS_PASS=

# Optional log bootstrap values. Runtime log rotation is managed in the admin settings page.
# LOG_FILE_ENABLED=true
# LOG_FILE_PATH=logs/app.log
# LOG_MAX_SIZE_MB=20
# LOG_MAX_BACKUPS=5
# LOG_MAX_AGE_DAYS=30
# LOG_COMPRESS=true
